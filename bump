#!/usr/bin/env bash

set -euo pipefail

if [[ $# -ne 1 ]]; then
  printf 'Uso: ./bump <version>\n' >&2
  exit 1
fi

version="$1"

if [[ ! "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+([-.][0-9A-Za-z.-]+)?$ ]]; then
  printf 'Version invalida: %s\n' "$version" >&2
  exit 1
fi

npm version "$version" --no-git-tag-version --allow-same-version

printf 'Version actualizada a %s en package.json y package-lock.json\n' "$version"
